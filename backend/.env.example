# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ─── Primary (remote) PostgreSQL ─────────────────────────────────────────────
# Set these to your remote/shared PostgreSQL server.
# If unreachable at runtime, the app automatically falls back to the local DB.
DB_HOST=your-remote-db-host
DB_PORT=5432
DB_NAME=iqdb
DB_USER=iquser
DB_PASSWORD=your-primary-db-password

# ─── Local Fallback PostgreSQL ────────────────────────────────────────────────
# Local PostgreSQL instance used when primary is unavailable.
# Run sql/local/ scripts to set this up before using local mode.
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=iq_local
LOCAL_DB_USER=iqlocal
LOCAL_DB_PASSWORD=iqlocal_password

# ─── Fallback / Health-Check Settings ────────────────────────────────────────
# FORCE_LOCAL_DB=true   → Always use local DB (skip primary entirely).
# FORCE_LOCAL_DB=false  → Use primary, fall back to local on failure (default).
FORCE_LOCAL_DB=false

# true = auto-switch back to primary once it recovers (default)
# false = stay on local until manual app restart
FALLBACK_AUTO_RECOVERY=true

# Milliseconds between health-check pings of both databases (default 30 s)
DB_HEALTH_CHECK_INTERVAL_MS=30000

# Max ms to wait when acquiring a DB connection (default 5 s)
DB_CONNECTION_TIMEOUT_MS=5000

# Max ms for the health-check ping before declaring a DB unhealthy (default 3 s)
DB_HEALTH_CHECK_TIMEOUT_MS=3000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Password Reset ───────────────────────────────────────────────────────────
# How long (minutes) a password-reset link stays valid (default 60)
PASSWORD_RESET_EXPIRES_MINUTES=60

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave EMAIL_HOST blank to use console-log fallback (no real email sent).
# Example values below use Gmail with an App Password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="IQ Dashboard" <no-reply@collectivercm.com>
